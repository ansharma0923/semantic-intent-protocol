# SIP — Semantic Intent Protocol
# Environment variable template. Copy to .env and fill in values.

# Optional: logging level (DEBUG | INFO | WARNING | ERROR)
SIP_LOG_LEVEL=INFO

# Optional: enable structured JSON logging (true | false)
SIP_JSON_LOGGING=false

# Broker API host/port (when running the FastAPI broker)
SIP_BROKER_HOST=127.0.0.1
SIP_BROKER_PORT=8000

# Policy: require human approval for high-risk write/execute actions (true | false)
SIP_REQUIRE_APPROVAL_HIGH_RISK=true
